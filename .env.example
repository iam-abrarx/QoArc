# GEMINI_API_KEY: Required for Gemini AI API calls.
# If used in an API route (server-side), no prefix is needed.
# If used directly in a client component, prefix with NEXT_PUBLIC_.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this app is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
# Prefix with NEXT_PUBLIC_ if accessed on the client.
NEXT_PUBLIC_APP_URL="https://www.qoarc.com"

# DATABASE_URL: Neon PostgreSQL connection string (pooled).
# Set this in Vercel project settings for production.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# BLOB_READ_WRITE_TOKEN: Vercel Blob storage token for image uploads.
# Set this in Vercel project settings for production.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."
